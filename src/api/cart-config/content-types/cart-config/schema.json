{
  "kind": "singleType",
  "collectionName": "cart_configs",
  "info": {
    "singularName": "cart-config",
    "pluralName": "cart-configs",
    "displayName": "Cart config"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid"
    },
    "pageTitle": {
      "type": "string"
    },
    "pageDescription": {
      "type": "string"
    },
    "cartModal": {
      "type": "component",
      "component": "cart.modal",
      "repeatable": false,
      "required": true
    },
    "SummaryResume": {
      "type": "component",
      "component": "cart.summary-resume",
      "repeatable": false,
      "required": true
    },
    "guestCheckoutEnabled": {
      "type": "boolean",
      "default": true
    },
    "minimumOrderAmount": {
      "type": "integer"
    },
    "freeShippingPercentage": {
      "type": "integer"
    },
    "allowOutOfStockPurchases": {
      "type": "boolean"
    },
    "currencyCode": {
      "type": "string"
    },
    "taxAmount": {
      "type": "integer"
    },
    "baseShippingCost": {
      "type": "decimal"
    },
    "localShippingCost": {
      "type": "decimal"
    },
    "localZipCodes": {
      "type": "string"
    },
    "enableBaseShipping": {
      "type": "boolean",
      "default": true
    },
    "enableLocalShipping": {
      "type": "boolean",
      "default": true
    },
    "enableFreeShipping": {
      "type": "boolean",
      "default": true
    },
    "enableEnvioclick": {
      "type": "boolean"
    },
    "BankTransferTitle": {
      "type": "string"
    },
    "allowBankTransfer": {
      "type": "boolean"
    },
    "bankDetails": {
      "type": "richtext"
    },
    "shippingConfiguration": {
      "type": "component",
      "component": "cart.shipping-configuration",
      "repeatable": false,
      "required": true
    }
  }
}
