{
  "kind": "singleType",
  "collectionName": "cart_configs",
  "info": {
    "singularName": "cart-config",
    "pluralName": "cart-configs",
    "displayName": "Cart config"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid"
    },
    "pageTitle": {
      "type": "string"
    },
    "pageDescription": {
      "type": "string"
    },
    "cartModal": {
      "type": "component",
      "component": "cart.modal",
      "repeatable": false,
      "required": true
    },
    "summarySubtotalText": {
      "type": "string"
    },
    "sumaryShippingText": {
      "type": "string"
    },
    "summaryBtnCheckout": {
      "type": "string"
    },
    "summaryMessage": {
      "type": "string"
    },
    "summaryShippingText": {
      "type": "string"
    },
    "summaryTaxText": {
      "type": "string"
    },
    "guestCheckoutEnabled": {
      "type": "boolean",
      "default": true
    },
    "minimumOrderAmount": {
      "type": "integer"
    },
    "freeShippingPercentage": {
      "type": "integer"
    },
    "allowOutOfStockPurchases": {
      "type": "boolean"
    },
    "currencyCode": {
      "type": "string"
    },
    "discountMode": {
      "type": "enumeration",
      "enum": [
        "N/A",
        "discountByQuantity",
        "discountByAmount"
      ]
    },
    "quantityDiscount": {
      "type": "integer"
    },
    "amountDiscount": {
      "type": "integer"
    },
    "shippingFreeText": {
      "type": "string"
    },
    "taxAmount": {
      "type": "integer"
    },
    "baseShippingCost": {
      "type": "decimal"
    },
    "summaryBadge": {
      "type": "component",
      "component": "cart.summary-badge-elements",
      "repeatable": true
    },
    "localShippingCost": {
      "type": "decimal"
    },
    "localZipCodes": {
      "type": "string"
    },
    "enableBaseShipping": {
      "type": "boolean",
      "default": true
    },
    "enableLocalShipping": {
      "type": "boolean",
      "default": true
    },
    "enableFreeShipping": {
      "type": "boolean",
      "default": true
    },
    "fallbackShippingText": {
      "type": "string",
      "default": "\"Se calcula después de compra\"*"
    },
    "fallbackShippingWarning": {
      "type": "string",
      "default": "\"Nos pondremos en contacto con usted para acordar el pago del envío\""
    },
    "enableEnvioclick": {
      "type": "boolean"
    }
  }
}
