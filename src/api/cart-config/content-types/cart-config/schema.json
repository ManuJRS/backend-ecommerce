{
  "kind": "singleType",
  "collectionName": "cart_configs",
  "info": {
    "singularName": "cart-config",
    "pluralName": "cart-configs",
    "displayName": "Cart config"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "pageTitle": {
      "type": "string"
    },
    "pageDescription": {
      "type": "string"
    },
    "cartModal": {
      "type": "component",
      "component": "cart.modal",
      "repeatable": false,
      "required": true
    },
    "summaryTitle": {
      "type": "string"
    },
    "summarySubtotalText": {
      "type": "string"
    },
    "sumaryShippingText": {
      "type": "string"
    },
    "summaryBtnCheckout": {
      "type": "string"
    },
    "summaryMessage": {
      "type": "string"
    },
    "summaryShippingText": {
      "type": "string"
    },
    "summaryTaxText": {
      "type": "string"
    },
    "guestCheckoutEnabled": {
      "type": "boolean",
      "default": true
    },
    "minimumOrderAmount": {
      "type": "integer"
    },
    "freeShippingPercentage": {
      "type": "integer"
    },
    "allowOutOfStockPurchases": {
      "type": "boolean"
    },
    "currencyCode": {
      "type": "string"
    },
    "discountMode": {
      "type": "enumeration",
      "enum": [
        "N/A",
        "discountByQuantity",
        "discountByAmount"
      ]
    },
    "quantityDiscount": {
      "type": "integer"
    },
    "amountDiscount": {
      "type": "integer"
    },
    "shippingFreeText": {
      "type": "string"
    },
    "taxAmount": {
      "type": "integer"
    },
    "summaryBadge": {
      "type": "component",
      "component": "cart.summary-badge-elements",
      "repeatable": true
    }
  }
}
