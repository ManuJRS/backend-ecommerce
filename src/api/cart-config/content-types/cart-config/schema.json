{
  "kind": "singleType",
  "collectionName": "cart_configs",
  "info": {
    "singularName": "cart-config",
    "pluralName": "cart-configs",
    "displayName": "Store Config"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "slug": {
      "type": "uid"
    },
    "pageTitle": {
      "type": "string"
    },
    "pageDescription": {
      "type": "string"
    },
    "cartModal": {
      "type": "component",
      "component": "cart.modal",
      "repeatable": false,
      "required": true
    },
    "SummaryResume": {
      "type": "component",
      "component": "cart.summary-resume",
      "repeatable": false,
      "required": true
    },
    "guestCheckoutEnabled": {
      "type": "boolean",
      "default": true
    },
    "shippingConfiguration": {
      "type": "component",
      "component": "cart.shipping-configuration",
      "repeatable": false,
      "required": true
    },
    "shippingMethods": {
      "type": "component",
      "component": "cart.shipping-methods",
      "repeatable": false,
      "required": true
    },
    "taxAndCurrency": {
      "type": "component",
      "component": "cart.tax-and-currency",
      "repeatable": false,
      "required": true
    }
  }
}
